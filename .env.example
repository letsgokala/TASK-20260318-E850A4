# ==========================================================================
# Activity Registration & Funding Audit Platform — Environment Configuration
# ==========================================================================
# Copy this file to .env and fill in real values before starting:
#   cp .env.example .env
#
# For encrypted deployment, encrypt .env with age and mount .env.age
# instead — see README.md "Encrypted sensitive configuration."
# ==========================================================================

# ── Database ──────────────────────────────────────────────────────────────
# Async PostgreSQL connection string.  The app uses asyncpg exclusively.
DATABASE_URL=postgresql+asyncpg://app_user:app_password@db:5432/eagle_point

# ── Secrets (must be overridden — the app refuses to start with defaults) ─
# JWT signing key. Use a random string of 64+ characters.
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-64-char-string

# Fernet key for PII encryption at rest (applicant_id_number, phone, email).
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SENSITIVE_FIELD_KEY=change-me-to-a-real-fernet-key

# ── Auth / lockout ────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOCKOUT_ATTEMPT_LIMIT=10
LOCKOUT_WINDOW_MINUTES=5
LOCKOUT_DURATION_MINUTES=30

# ── Feature flags ─────────────────────────────────────────────────────────
# SHA-256 duplicate-file detection endpoint (disabled by default).
ENABLE_DUPLICATE_CHECK_API=false

# ── Fail-closed modes (all default to "1" = strict) ──────────────────────
# Set to "0" to fall back to fail-open where noted. See README "Fail-closed
# modes" and docs/design.md for semantics.
AUDIT_FAIL_CLOSED=1
DECRYPT_FAIL_CLOSED=1
VALIDATION_FAIL_CLOSED=1
ALERT_FAIL_CLOSED=1

# ── Testing (do not set in production) ────────────────────────────────────
# TESTING=1  # skips secret validation; used by the test harness only
